<script>
    // Home-specific motion. Shared chrome (menu/cursor/lenis/modal/reveal/ripple)
    // is wired in /js/site.js, which sets window.lenisInstance before this runs.
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const isFinePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        const lenisInstance = window.lenisInstance || null;

        // Scroll-velocity marquee — speed and direction respond to scroll.
        // Falls back to the CSS @keyframes if Lenis isn't running.
        const marqueeTracks = document.querySelectorAll('.marquee-track');
        if (!prefersReducedMotion && lenisInstance && marqueeTracks.length >= 2) {
            marqueeTracks.forEach((t) => { t.style.animation = 'none'; t.style.willChange = 'transform'; });

            let offset = 0;
            let scrollVelocity = 0;
            let trackWidth = marqueeTracks[0].offsetWidth || 1;

            const recomputeWidth = () => { trackWidth = marqueeTracks[0].offsetWidth || trackWidth; };
            window.addEventListener('resize', recomputeWidth);
            window.addEventListener('load', recomputeWidth);

            lenisInstance.on('scroll', (e) => {
                scrollVelocity = (e && typeof e.velocity === 'number')
                    ? e.velocity
                    : (lenisInstance.velocity || 0);
            });

            const baseSpeed = 0.55;
            const boostFactor = 0.45;
            const maxBoost = 7;

            const tickMarquee = () => {
                const direction = scrollVelocity >= 0 ? -1 : 1;
                const boost = Math.min(Math.abs(scrollVelocity) * boostFactor, maxBoost);
                offset += (baseSpeed + boost) * direction;

                if (offset <= -trackWidth) offset += trackWidth;
                if (offset >= 0) offset -= trackWidth;

                for (let i = 0; i < marqueeTracks.length; i++) {
                    marqueeTracks[i].style.transform = `translate3d(${offset}px, 0, 0)`;
                }
                requestAnimationFrame(tickMarquee);
            };
            requestAnimationFrame(tickMarquee);
        }

        // Hero parallax — headline lifts and fades, aura sinks and scales.
        const heroSection = document.getElementById('hero');
        const heroHeadlineEl = document.querySelector('.hero-headline');
        const heroAuraEl = document.querySelector('.hero-aura');
        if (!prefersReducedMotion && heroSection) {
            if (heroHeadlineEl) {
                gsap.to(heroHeadlineEl, {
                    yPercent: -8,
                    opacity: 0.25,
                    ease: 'none',
                    scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.6 },
                });
            }
            if (heroAuraEl) {
                gsap.to(heroAuraEl, {
                    yPercent: 18,
                    scale: 1.08,
                    ease: 'none',
                    scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.6 },
                });
            }
        }

        // Magnetic buttons
        if (!prefersReducedMotion && isFinePointer) {
            document.querySelectorAll('.magnetic').forEach((el) => {
                const inner = el.querySelectorAll('.magnetic-text');
                const strength = 16;
                el.addEventListener('mousemove', (e) => {
                    const rect = el.getBoundingClientRect();
                    const relX = (e.clientX - rect.left - rect.width / 2) / (rect.width / 2);
                    const relY = (e.clientY - rect.top - rect.height / 2) / (rect.height / 2);
                    gsap.to(el, { x: relX * strength, y: relY * strength, duration: 0.6, ease: 'power3.out' });
                    inner.forEach((i) => {
                        gsap.to(i, { x: relX * strength * 0.45, y: relY * strength * 0.45, duration: 0.6, ease: 'power3.out' });
                    });
                });
                el.addEventListener('mouseleave', () => {
                    gsap.to(el, { x: 0, y: 0, duration: 0.85, ease: 'elastic.out(1, 0.5)' });
                    inner.forEach((i) => {
                        gsap.to(i, { x: 0, y: 0, duration: 0.85, ease: 'elastic.out(1, 0.5)' });
                    });
                });
            });
        }

        // Logo entrance
        if (document.querySelector('.logo-anim')) {
            gsap.from('.logo-anim', { duration: 1.5, y: -20, opacity: 0, ease: 'power3.out', delay: 0.2 });
        }

        // --- Case study modals -------------------------------------------------
        // Generic handler for the per-case-study "View more" modals. Reuses the
        // brief-modal CSS classes for visual consistency but lives independently
        // from /js/site.js's brief-modal IIFE so the two don't interfere.
        (() => {
            const triggers = document.querySelectorAll('[data-case-open]');
            if (!triggers.length) return;

            let openModal = null;
            let lastFocused = null;
            let savedScrollY = 0;
            const FOCUSABLES = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

            const lockScroll = () => {
                savedScrollY = window.scrollY || document.documentElement.scrollTop || 0;
                document.body.style.position = 'fixed';
                document.body.style.top = `-${savedScrollY}px`;
                document.body.style.left = '0';
                document.body.style.right = '0';
                document.body.style.width = '100%';
                document.body.classList.add('brief-modal-open');
                if (window.lenisInstance) { try { window.lenisInstance.stop(); } catch (_) {} }
            };
            const unlockScroll = () => {
                document.body.style.position = '';
                document.body.style.top = '';
                document.body.style.left = '';
                document.body.style.right = '';
                document.body.style.width = '';
                document.body.classList.remove('brief-modal-open');
                window.scrollTo(0, savedScrollY);
                if (window.lenisInstance) { try { window.lenisInstance.start(); } catch (_) {} }
            };

            const open = (modal) => {
                if (!modal || openModal) return;
                openModal = modal;
                lastFocused = document.activeElement;
                modal.hidden = false;
                lockScroll();
                if (typeof lucide !== 'undefined' && lucide.createIcons) lucide.createIcons();
                requestAnimationFrame(() => {
                    const first = modal.querySelector(FOCUSABLES);
                    first && first.focus({ preventScroll: true });
                });
            };

            const close = () => {
                if (!openModal) return;
                openModal.hidden = true;
                openModal = null;
                unlockScroll();
                if (lastFocused && typeof lastFocused.focus === 'function') {
                    lastFocused.focus({ preventScroll: true });
                }
            };

            triggers.forEach((btn) => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const id = btn.getAttribute('data-case-open');
                    open(document.getElementById(id));
                });
            });

            // Wire close affordances on every case-study modal. Each modal has
            // a [data-close] backdrop + a [data-close] button.
            document.querySelectorAll('.brief-modal[id^="case-"]').forEach((modal) => {
                modal.querySelectorAll('[data-close]').forEach((el) => {
                    el.addEventListener('click', (e) => { e.preventDefault(); close(); });
                });
            });

            document.addEventListener('keydown', (e) => {
                if (!openModal) return;
                if (e.key === 'Escape') { e.preventDefault(); close(); return; }
                if (e.key !== 'Tab') return;
                const focusables = Array.from(openModal.querySelectorAll(FOCUSABLES))
                    .filter((el) => el.offsetParent !== null);
                if (!focusables.length) return;
                const first = focusables[0];
                const last = focusables[focusables.length - 1];
                if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
                else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
            });
        })();
    });
</script>

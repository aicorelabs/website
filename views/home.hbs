        <section id="faq" class="py-20 sm:py-28 md:py-36 border-t border-white/5">
            <div class="max-w-[1400px] mx-auto px-6 sm:px-10 md:px-14 grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
                <div class="reveal md:col-span-4">

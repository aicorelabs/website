<section class="relative pt-32 pb-16 px-4 sm:px-6 overflow-hidden">
    <div class="glow-point top-0 left-1/2 -translate-x-1/2"></div>
    <div class="max-w-5xl mx-auto text-center">
        <div class="reveal inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-[#0145F2] text-xs font-mono mb-8">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#0145F2] opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#0145F2]"></span>
            </span>
            INTERACTIVE PLAYGROUND
        </div>
        <h1 class="reveal stagger-1 text-4xl sm:text-5xl md:text-7xl font-medium tracking-tight leading-[1.05] mb-6 text-white">
            Zeffron <span class="text-gradient">Live Lab</span>
        </h1>
        <p class="reveal stagger-2 text-base sm:text-lg md:text-xl text-[#A8A8A8] max-w-2xl mx-auto mb-10 font-light leading-relaxed">
            Experience our engineering capabilities firsthand. Real-time demos, no login required.
        </p>
    </div>
</section>

<section id="demos" class="py-16 px-8 sm:px-6 border-t border-white/5 bg-[#0A0A0A]">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 gap-12">
            <div class="reveal glass-panel p-8 rounded-2xl relative overflow-hidden group">
                <div class="flex items-start justify-between mb-8">
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                            <div class="p-2 bg-[#0145F2]/10 rounded-lg">
                                <i data-lucide="boxes" class="w-6 h-6 text-[#0145F2]"></i>
                            </div>
                            <h3 class="text-2xl font-medium text-white">Supply Chain Intelligence</h3>
                        </div>
                        <p class="text-[#888] text-sm max-w-xl">
                            Predictive inventory management using historical sales data and seasonal forecasting models.
                        </p>
                    </div>
                    <button onclick="runSupplyChainAI()" class="px-6 py-3 bg-[#0145F2] text-white text-sm font-medium rounded hover:bg-[#0039cc] transition-colors flex items-center gap-2">
                        <i data-lucide="refresh-cw" class="w-4 h-4"></i> Run Forecast Model
                    </button>
                </div>

                <div class="overflow-x-auto bg-[#111] border border-white/10 rounded-lg">
                    <table class="w-full text-left text-sm text-[#AAA]">
                        <thead class="bg-white/5 text-white font-mono uppercase text-xs tracking-wider">
                            <tr>
                                <th class="p-4">SKU</th>
                                <th class="p-4">Product Name</th>
                                <th class="p-4">Current Stock</th>
                                <th class="p-4">Predicted Demand (30d)</th>
                                <th class="p-4">Risk Level</th>
                                <th class="p-4">AI Recommendation</th>
                            </tr>
                        </thead>
                        <tbody id="supply-chain-body" class="divide-y divide-white/5">
                            <tr><td colspan="6" class="p-8 text-center text-[#666]">System Ready. Click 'Run Forecast Model' to analyze.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="reveal glass-panel p-8 rounded-2xl relative overflow-hidden group stagger-1">
                <div class="flex items-start justify-between mb-8">
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                            <div class="p-2 bg-[#977DFF]/10 rounded-lg">
                                <i data-lucide="message-square-code" class="w-6 h-6 text-[#977DFF]"></i>
                            </div>
                            <h3 class="text-2xl font-medium text-white">CX Intent Analysis</h3>
                        </div>
                        <p class="text-[#888] text-sm max-w-xl">
                            Real-time classification of customer tickets to automate routing and draft responses.
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-2 bg-[#111] border border-white/10 rounded-lg p-6">
                        <div class="text-xs font-mono text-[#666] uppercase mb-4">Incoming Ticket #9921</div>
                        <div class="flex gap-4 mb-6">
                            <div class="w-10 h-10 rounded-full bg-[#333] flex items-center justify-center text-white font-medium">JD</div>
                            <div>
                                <div class="text-white font-medium">John Doe</div>
                                <div class="text-[#666] text-xs">Enterprise Client &bull; 2 mins ago</div>
                            </div>
                        </div>
                        <p class="text-[#E5E5E5] leading-relaxed mb-6">
                            "Hi, we're seeing a discrepancy in the API usage billing for March. The dashboard shows 50k calls but the invoice is for 75k. Can you check this immediately? We need to close our books."
                        </p>
                        <div class="flex gap-2">
                            <button onclick="analyzeTicket()" class="px-4 py-2 border border-[#977DFF] text-[#977DFF] text-xs font-medium rounded hover:bg-[#977DFF] hover:text-white transition-colors">
                                Analyze Intent
                            </button>
                        </div>
                    </div>

                    <div class="bg-[#111] border border-white/10 rounded-lg p-6 relative overflow-hidden">
                        <div id="cx-analysis-overlay" class="absolute inset-0 bg-[#111] z-10 flex items-center justify-center text-[#666] text-xs">
                            Waiting for analysis...
                        </div>
                        <div class="space-y-6">
                            <div>
                                <div class="text-xs font-mono text-[#666] uppercase mb-2">Detected Intent</div>
                                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-500/10 text-red-400 text-xs font-medium border border-red-500/20">
                                    <i data-lucide="alert-circle" class="w-3 h-3"></i> Billing Dispute
                                </div>
                            </div>
                            <div>
                                <div class="text-xs font-mono text-[#666] uppercase mb-2">Sentiment Score</div>
                                <div class="w-full bg-[#333] h-1.5 rounded-full mb-1">
                                    <div class="bg-orange-500 h-1.5 rounded-full" style="width: 75%"></div>
                                </div>
                                <div class="flex justify-between text-[10px] text-[#888]">
                                    <span>Negative</span>
                                    <span>Urgent</span>
                                </div>
                            </div>
                            <div>
                                <div class="text-xs font-mono text-[#666] uppercase mb-2">Suggested Action</div>
                                <div class="p-3 bg-[#222] rounded border border-white/5 text-xs text-[#AAA]">
                                    Route to <strong>Finance Tier 2</strong>. <br>
                                    Auto-draft "Billing Investigation" email.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="reveal glass-panel p-8 rounded-2xl relative overflow-hidden group stagger-2">
                <div class="flex items-start justify-between mb-8">
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                            <div class="p-2 bg-[#F7A505]/10 rounded-lg">
                                <i data-lucide="file-spreadsheet" class="w-6 h-6 text-[#F7A505]"></i>
                            </div>
                            <h3 class="text-2xl font-medium text-white">Automated Ledger Reconciliation</h3>
                        </div>
                        <p class="text-[#888] text-sm max-w-xl">
                            AI-powered matching of bank transactions against internal ledger entries to detect anomalies.
                        </p>
                    </div>
                    <div class="text-right">
                        <div class="text-xs text-[#666] uppercase tracking-widest mb-1">Unreconciled Amount</div>
                        <div class="text-2xl font-mono text-white" id="ledger-total">£14,250.00</div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="bg-[#111] border border-white/10 rounded-lg overflow-hidden">
                        <div class="p-3 border-b border-white/5 bg-white/5 text-xs font-mono text-white flex justify-between">
                            <span>Bank Feed (Live)</span>
                            <span class="text-[#F7A505]">Processing...</span>
                        </div>
                        <div class="p-4 space-y-3" id="ledger-feed"></div>
                    </div>

                    <div class="bg-[#111] border border-white/10 rounded-lg p-6 flex flex-col justify-center items-center text-center">
                        <div id="audit-status" class="mb-6">
                            <div class="w-16 h-16 rounded-full border-2 border-[#333] flex items-center justify-center mx-auto mb-4">
                                <i data-lucide="shield-check" class="w-8 h-8 text-[#333]"></i>
                            </div>
                            <h4 class="text-white font-medium mb-2">Audit System Idle</h4>
                            <p class="text-[#666] text-xs">Ready to process transactions.</p>
                        </div>
                        <button onclick="startReconciliation()" class="w-full py-3 border border-[#F7A505] text-[#F7A505] text-sm font-medium rounded hover:bg-[#F7A505] hover:text-black transition-colors">
                            Start Reconciliation Process
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function runSupplyChainAI() {
        const tbody = document.getElementById('supply-chain-body');
        tbody.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-[#0145F2] animate-pulse">Running Neural Forecast Model...</td></tr>';

        setTimeout(() => {
            const products = [
                { sku: 'SKU-8821', name: 'Wireless Sensor Module', stock: 142, demand: 180, risk: 'High' },
                { sku: 'SKU-9932', name: 'Industrial Controller', stock: 50, demand: 45, risk: 'Low' },
                { sku: 'SKU-1102', name: 'Lithium Battery Pack', stock: 12, demand: 85, risk: 'Critical' },
                { sku: 'SKU-4451', name: 'Display Panel 4K', stock: 200, demand: 110, risk: 'Low' },
            ];

            let html = '';
            products.forEach(p => {
                let riskColor = p.risk === 'Critical' ? 'text-red-500' : (p.risk === 'High' ? 'text-orange-500' : 'text-green-500');
                let action = p.risk === 'Critical' ? '<button class="px-3 py-1 bg-red-500/10 text-red-500 border border-red-500/20 rounded text-xs hover:bg-red-500 hover:text-white transition-colors">Auto-Reorder</button>' :
                             (p.risk === 'High' ? '<button class="px-3 py-1 bg-orange-500/10 text-orange-500 border border-orange-500/20 rounded text-xs hover:bg-orange-500 hover:text-black transition-colors">Review</button>' : '<span class="text-[#666] text-xs">No Action</span>');

                html += `
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="p-4 font-mono text-xs text-[#666]">${p.sku}</td>
                        <td class="p-4 text-white">${p.name}</td>
                        <td class="p-4 font-mono">${p.stock}</td>
                        <td class="p-4 font-mono">${p.demand} <span class="text-[10px] text-[#666] ml-1">units</span></td>
                        <td class="p-4 ${riskColor} font-medium text-xs uppercase">${p.risk}</td>
                        <td class="p-4">${action}</td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }, 1200);
    }

    function analyzeTicket() {
        const overlay = document.getElementById('cx-analysis-overlay');
        overlay.style.display = 'flex';
        overlay.innerHTML = '<div class="flex flex-col items-center gap-2"><i data-lucide="loader-2" class="w-6 h-6 animate-spin text-[#977DFF]"></i><span>Processing NLP...</span></div>';
        if (typeof lucide !== 'undefined') lucide.createIcons();

        setTimeout(() => {
            overlay.style.display = 'none';
        }, 1500);
    }

    function startReconciliation() {
        const feed = document.getElementById('ledger-feed');
        const status = document.getElementById('audit-status');

        feed.innerHTML = '';
        status.innerHTML = `
            <div class="w-16 h-16 rounded-full border-2 border-[#F7A505] border-t-transparent animate-spin mx-auto mb-4"></div>
            <h4 class="text-white font-medium mb-2">Scanning Ledger...</h4>
            <p class="text-[#666] text-xs">Matching transaction IDs</p>
        `;

        const transactions = [
            { id: 'TXN-8842', amount: '£4,200.00', vendor: 'AWS EMEA', status: 'match' },
            { id: 'TXN-8843', amount: '£150.00', vendor: 'Uber Business', status: 'match' },
            { id: 'TXN-8844', amount: '£9,900.00', vendor: 'Unknown Vendor', status: 'anomaly' },
            { id: 'TXN-8845', amount: '£1,200.00', vendor: 'WeWork', status: 'match' },
        ];

        let delay = 500;
        transactions.forEach((t, i) => {
            setTimeout(() => {
                const div = document.createElement('div');
                div.className = "flex items-center justify-between p-3 bg-[#222] rounded border border-white/5 text-sm animate-in fade-in slide-in-from-bottom-2";

                let icon = t.status === 'match' ? '<i data-lucide="check-circle-2" class="w-4 h-4 text-green-500"></i>' : '<i data-lucide="alert-triangle" class="w-4 h-4 text-red-500"></i>';
                let statusText = t.status === 'match' ? '<span class="text-green-500 text-xs">Verified</span>' : '<span class="text-red-500 text-xs">Flagged</span>';

                div.innerHTML = `
                    <div class="flex items-center gap-3">
                        ${icon}
                        <div>
                            <div class="text-white">${t.vendor}</div>
                            <div class="text-[#666] text-xs font-mono">${t.id}</div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-white font-mono">${t.amount}</div>
                        ${statusText}
                    </div>
                `;
                feed.appendChild(div);
                if (typeof lucide !== 'undefined') lucide.createIcons();

                if (i === transactions.length - 1) {
                    setTimeout(() => {
                        status.innerHTML = `
                            <div class="w-16 h-16 rounded-full bg-red-500/10 flex items-center justify-center mx-auto mb-4 border border-red-500/20">
                                <span class="text-red-500 font-bold text-xl">1</span>
                            </div>
                            <h4 class="text-white font-medium mb-2">Anomaly Detected</h4>
                            <p class="text-[#666] text-xs">Action required on TXN-8844</p>
                            <button class="mt-4 px-4 py-2 bg-red-500 text-white text-xs rounded hover:bg-red-600 transition-colors">View Report</button>
                        `;
                    }, 500);
                }
            }, delay);
            delay += 800;
        });
    }
</script>

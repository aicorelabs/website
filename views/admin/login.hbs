<style>
    body.tool-body {
        margin: 0; min-height: 100vh;
        background: #0A0A0A; color: #E5E5E5;
        font-family: 'Inter', sans-serif;
        display: flex; align-items: center; justify-content: center;
        padding: 32px 16px;
        position: relative; overflow: hidden;
    }
    /* Atmospheric blue wash, same dialect as the rest of the site */
    body.tool-body::before {
        content: ''; position: absolute; inset: -20%;
        background:
            radial-gradient(ellipse 50% 40% at 30% 30%, rgba(1,69,242,0.18), transparent 60%),
            radial-gradient(ellipse 40% 30% at 75% 70%, rgba(151,125,255,0.10), transparent 60%);
        filter: blur(20px); pointer-events: none; z-index: 0;
    }

    .login-card {
        position: relative; z-index: 1;
        width: 100%; max-width: 420px;
        padding: 40px 36px 36px;
        background: rgba(17,17,17,0.85);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        backdrop-filter: blur(20px);
        box-shadow: 0 30px 80px rgba(0,0,0,0.4);
    }

    .login-eyebrow {
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        letter-spacing: 0.3em; text-transform: uppercase; color: #888;
        display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
    }
    .login-eyebrow::before {
        content: ''; display: block; width: 22px; height: 1px; background: #0145F2;
    }

    .login-card h1 {
        font-family: 'Archivo', sans-serif; font-weight: 600;
        font-size: 28px; letter-spacing: -0.02em; line-height: 1.05;
        margin: 0 0 8px 0; color: #fff;
    }
    .login-card p.sub {
        margin: 0 0 28px 0; color: #888; font-size: 14px;
    }

    label {
        display: block; margin-bottom: 6px;
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        letter-spacing: 0.25em; text-transform: uppercase; color: #888;
    }
    input[type="text"], input[type="password"] {
        width: 100%; box-sizing: border-box;
        background: transparent; border: 0;
        border-bottom: 1px solid rgba(255,255,255,0.18);
        color: #F5F4F0; font-family: inherit; font-size: 15px;
        padding: 10px 0; margin-bottom: 22px;
        transition: border-color .35s cubic-bezier(0.16,1,0.3,1);
        border-radius: 0;
    }
    input[type="text"]:focus, input[type="password"]:focus {
        outline: none; border-bottom-color: #0145F2;
    }
    input[type="text"]::placeholder, input[type="password"]::placeholder {
        color: #555;
    }

    .login-error {
        background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.3);
        color: #FFB3B3; padding: 10px 14px; border-radius: 8px;
        font-size: 13px; margin-bottom: 18px;
        display: flex; align-items: center; gap: 8px;
    }

    button[type="submit"] {
        width: 100%; box-sizing: border-box;
        background: #0145F2; color: #fff;
        border: 0; border-radius: 10px;
        padding: 14px 18px; font-size: 14px;
        font-family: inherit; font-weight: 600;
        letter-spacing: 0.01em; cursor: pointer;
        transition: background .25s, transform .25s;
    }
    button[type="submit"]:hover { background: #0036c7; }
    button[type="submit"]:active { transform: translateY(1px); }
    button[type="submit"]:disabled { opacity: 0.6; cursor: wait; }

    .login-footer {
        margin-top: 24px; padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,0.06);
        color: #555; font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
        display: flex; justify-content: space-between; align-items: center;
    }
    .login-footer a { color: #888; text-decoration: none; transition: color .2s; }
    .login-footer a:hover { color: #fff; }
</style>

<form class="login-card" method="POST" action="/backstage/login" autocomplete="off">
    <p class="login-eyebrow">Zeffron · Admin</p>
    <h1>Sign in.</h1>
    <p class="sub">Internal access to submissions and tools.</p>

    {{#if error}}
        <div class="login-error" role="alert">
            <span>⚠</span>
            <span>{{error}}</span>
        </div>
    {{/if}}

    <label for="username">Username</label>
    <input id="username" name="username" type="text" required autofocus autocomplete="username" value="{{username}}">

    <label for="password">Password</label>
    <input id="password" name="password" type="password" required autocomplete="current-password">

    <input type="hidden" name="next" value="{{next}}">

    <button type="submit">Sign in</button>

    <div class="login-footer">
        <span>Read-only · 7-day session</span>
        <a href="/">← Back to site</a>
    </div>
</form>

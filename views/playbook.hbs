            </div>
        </div>
    </section>

    <!-- ───── MICRO-FAQ — three quick objections handled ───── -->
    <section class="py-16 sm:py-20 border-t border-white/5">
        <div class="max-w-[820px] mx-auto px-6 sm:px-10">
            <p class="text-[10px] font-mono tracking-[0.3em] uppercase text-[#666] mb-6 text-center">Quick answers</p>
            <div class="border-t border-white/10">
                <details class="faq-item">
                    <summary class="faq-q">Is this actually free?</summary>
                    <div class="faq-a"><p>Yes. No cost, no trial, no card. Email + name and the playbook lands in your inbox.</p></div>
                </details>
                <details class="faq-item">
                    <summary class="faq-q">Do I need to be technical?</summary>
                    <div class="faq-a"><p>No. Built for non-technical founders. If you can describe your idea in a few sentences, every prompt in here works for you.</p></div>
                </details>
                <details class="faq-item">
                    <summary class="faq-q">What's Zeffron?</summary>
                    <div class="faq-a"><p>An AI &amp; MVP studio. We build investable AI products for non-technical founders in 10 days. This playbook is the framework we use internally — given away free.</p></div>
                </details>
            </div>
        </div>
    </section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Hero parallax — headline lifts and aura sinks, same recipe as home.
        if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const heroSection = document.getElementById('hero');
            const heroHeadlineEl = document.querySelector('.hero-headline');
            const heroAuraEl = document.querySelector('.playbook-aura');
            const bookEl = document.querySelector('.book-cover');
            if (!prefersReducedMotion && heroSection) {
                if (heroHeadlineEl) {
                    gsap.to(heroHeadlineEl, {
                        yPercent: -6, opacity: 0.4, ease: 'none',
                        scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.6 },
                    });
                }
                if (heroAuraEl) {
                    gsap.to(heroAuraEl, {
                        yPercent: 14, scale: 1.06, ease: 'none',
                        scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.6 },
                    });
                }
                if (bookEl) {
                    // Sublte vertical lift on scroll so the cover feels anchored
                    // in the page rather than fixed in space.
                    gsap.to(bookEl, {
                        yPercent: -12, ease: 'none',
                        scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.7 },
                    });
                }
            }
        }

        // Form handler — POSTs JSON to /api/playbook, swaps in thanks card on success.
        const form = document.getElementById('playbook-form-el');
        if (!form) return;
        const thanks = document.getElementById('pb-thanks');
        const errorEl = document.getElementById('pb-error');
        const submitBtn = document.getElementById('pb-submit');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (errorEl) { errorEl.hidden = true; errorEl.textContent = ''; }
            if (!form.checkValidity()) { form.reportValidity(); return; }

            const originalLabel = submitBtn ? submitBtn.innerHTML : null;
            if (submitBtn) { submitBtn.disabled = true; submitBtn.innerHTML = 'Sending…'; }

            try {
                const body = Object.fromEntries(new FormData(form).entries());
                const res = await fetch('/api/playbook', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                    body: JSON.stringify(body),
                });
                const json = await res.json().catch(() => ({}));
                if (!res.ok) throw new Error(json.error || `Request failed (${res.status})`);
                if (thanks) {
                    form.hidden = true;
                    thanks.hidden = false;
                    if (typeof lucide !== 'undefined' && lucide.createIcons) lucide.createIcons();
                    thanks.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            } catch (err) {
                if (errorEl) {
                    errorEl.textContent = `Couldn't send — ${err.message}. Email hello@zeffron.ai and we'll send it manually.`;
                    errorEl.hidden = false;
                }
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalLabel;
                    if (typeof lucide !== 'undefined' && lucide.createIcons) lucide.createIcons();
                }
            }
        });
    });
</script>

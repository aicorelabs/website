    <style>
        /* === Playbook page — book-cover hero === */
        .playbook-wrap { position: relative; overflow: hidden; }

        /* Atmospheric blue wash behind the hero, sits below the cover */
        .playbook-aura {
            position: absolute; inset: -10% -10% auto -10%; height: 90vh;
            background:
                radial-gradient(ellipse 60% 50% at 70% 35%, rgba(1,69,242,0.22), transparent 60%),
                radial-gradient(ellipse 50% 40% at 30% 60%, rgba(151,125,255,0.10), transparent 60%);
            filter: blur(20px); pointer-events: none; z-index: 0;
        }

        /* Book cover — uses the founder_play_book.png artwork. The stage gives
           perspective so the rotateY/rotateX on the cover reads as 3D. The
           image aspect is preserved by intrinsic width; the float animation
           gives idle motion without competing with the scroll parallax. */
        .book-stage {
            perspective: 1800px;
            display: flex; justify-content: center;
            padding: 1rem;
        }
        .book-cover {
            display: block;
            width: clamp(240px, 32vw, 380px);
            height: auto;
            border-radius: 3px 8px 8px 3px;
            box-shadow:
                inset 14px 0 24px -10px rgba(0,0,0,0.45),
                -30px 40px 80px rgba(0,0,0,0.55),
                0 0 60px rgba(1,69,242,0.10);
            transform: rotateY(-14deg) rotateX(2deg);
            transform-style: preserve-3d;
            transform-origin: left center;
            transition: transform 0.9s cubic-bezier(0.2, 1, 0.2, 1);
            will-change: transform;
        }
        .book-cover:hover { transform: rotateY(-6deg) rotateX(0deg) translateY(-4px); }

        /* Floating idle motion — kept subtle so it doesn't fight with the
           parallax scroll handler in the script block. */
        @keyframes bookFloat {
            0%, 100% { transform: rotateY(-14deg) rotateX(2deg) translateY(0); }
            50%      { transform: rotateY(-12deg) rotateX(1deg) translateY(-8px); }
        }
        @media (prefers-reduced-motion: no-preference) {
            .book-cover { animation: bookFloat 6s ease-in-out infinite; }
            .book-cover:hover { animation-play-state: paused; }
        }

        /* Trust pill row under the CTA */
        .trust-row { display: flex; flex-wrap: wrap; gap: 0.75rem; }
        .trust-pill {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
            color: #888; padding: 0.45rem 0.75rem;
            border: 1px solid rgba(255,255,255,0.10); border-radius: 999px;
            background: rgba(255,255,255,0.02);
        }
    </style>

    <!-- ───── HERO — book cover + sales pitch ───── -->

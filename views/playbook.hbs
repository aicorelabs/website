                            </select>
                        </div>
                        <div>
                            <label class="brief-label" for="pb-stage">Your stage</label>
                            <select class="brief-input brief-select" id="pb-stage" name="stage" required>
                                <option value="">Select one</option>
                                <option>Just an idea</option>
                                <option>Validating</option>
                                <option>Ready to build</option>
                                <option>Already building</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex flex-col gap-3 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg w-full" id="pb-submit">
                            Send me the playbook
                            <i data-lucide="arrow-right" class="btn-icon"></i>
                        </button>
                        <p class="text-[#666] text-xs text-center">No spam. No sales calls you didn't ask for. Just the playbook.</p>
                        <span class="text-[#FF6B6B] text-sm text-center" id="pb-error" hidden></span>
                    </div>
                </form>

                <div id="pb-thanks" class="ai-audit-card text-center" hidden>
                    <p class="text-[10px] font-mono tracking-[0.3em] uppercase text-[#0145F2] mb-3">You're in</p>
                    <h3 class="text-3xl sm:text-4xl font-medium text-white mb-4 tracking-tight">Your playbook is ready.</h3>
                    <p class="text-[#A8A8A8] mb-6 leading-relaxed max-w-md mx-auto">
                        Download <em class="not-italic text-white">The Founder's AI Prompt Playbook</em> below. We've also emailed you a copy — check spam if it hasn't landed in two minutes.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
                        <a href="/Founder's Playbook.pdf" download class="btn btn-primary">
                            Download the playbook
                            <i data-lucide="arrow-down" class="btn-icon"></i>
                        </a>
                        <a href="https://cal.com/zeffron-ai/30min" class="btn btn-secondary">
                            Or book a call with Zeffron
                            <i data-lucide="arrow-up-right" class="btn-icon"></i>
                        </a>

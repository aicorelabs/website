            </div>

            <div class="reveal">
                <form id="playbook-form-el" class="space-y-8" method="POST" action="/api/playbook" novalidate>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-7">
                        <div>
                            <label class="brief-label" for="pb-name">First name</label>

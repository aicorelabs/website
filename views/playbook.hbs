            </div>

            <!-- Right: book cover -->
            <div class="lg:col-span-5 order-1 lg:order-2">
                <div class="book-stage">
                    <img src="/assets/founder_play_book.png"
                         alt="The Founder's AI Prompt Playbook — cover"
                         class="book-cover" />
                </div>
            </div>
        </div>
    </section>

    <!-- ───── FORM — direct conversion ───── -->
    <section id="playbook-form" class="py-16 sm:py-20 md:py-24 border-t border-white/5 bg-[#080808]">
        <div class="max-w-[820px] mx-auto px-6 sm:px-10">
            <div class="reveal mb-10 md:mb-12 text-center">
                <p class="text-[10px] font-mono tracking-[0.3em] uppercase text-[#0145F2] mb-4">Free · Delivered instantly</p>
                <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight text-white leading-[1.05] mb-3">

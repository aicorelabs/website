<section class="relative pt-24 pb-16 md:pt-32 md:pb-24 px-4 sm:px-6 overflow-hidden">
    <div class="glow-point top-0 left-1/2 -translate-x-1/2"></div>
    <div class="max-w-5xl mx-auto text-center">
        <div class="reveal inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-[#97B9CD] text-xs font-mono mb-8">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#0145F2] opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#0145F2]"></span>
            </span>
            INSIGHTS & UPDATES
        </div>
        <h1 class="reveal stagger-1 text-4xl sm:text-5xl md:text-6xl font-medium tracking-tight leading-[1.05] mb-6 text-white">
            The Zeffron <span class="text-gradient">Blog</span>
        </h1>
        <p class="reveal stagger-2 text-base sm:text-lg md:text-xl text-[#A8A8A8] max-w-2xl mx-auto mb-10 font-light leading-relaxed">
            Insights on AI, software development, and building products that scale.
        </p>
    </div>
</section>

<section class="py-16 px-4 sm:px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {{#each posts}}
        <article class="reveal{{#if stagger}} stagger-{{stagger}}{{/if}}">
            <a href="{{href}}" class="group block glass-panel rounded-xl overflow-hidden blog-card h-full flex flex-col border border-white/10 bg-white/5">
                <div class="aspect-video bg-gradient-to-br {{imageGradient}} flex items-center justify-center overflow-hidden {{#if imageBg}}{{imageBg}}{{/if}} relative">
                    <img src="{{image}}" alt="{{imageAlt}}" class="w-full h-full {{imageFit}} {{imageOpacity}} group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-6 flex-1 flex flex-col">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="px-3 py-1 rounded-full bg-[#0145F2]/10 border border-[#0145F2]/20 text-[#0145F2] text-xs font-mono">
                            {{category}}
                        </span>
                    </div>
                    <h3 class="text-xl font-medium text-white mb-3 group-hover:text-[#0145F2] transition-colors leading-tight">
                        {{title}}
                    </h3>
                    <p class="text-[#A8A8A8] text-sm leading-relaxed mb-4 flex-1">
                        {{excerpt}}
                    </p>
                    <div class="flex items-center justify-between text-xs text-[#888] mt-auto">
                        <span class="font-mono">{{date}}</span>
                        <span>{{readTime}}</span>
                    </div>
                </div>
            </a>
        </article>
        {{/each}}
    </div>
</section>

<section class="py-16 sm:py-20 px-4 sm:px-6 max-w-4xl mx-auto">
    <div class="reveal glass-panel rounded-2xl p-8 sm:p-12 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#0145F2]/20 bg-[#0145F2]/10 text-[#0145F2] text-xs font-mono mb-6">
            <i data-lucide="mail" class="w-3 h-3"></i>
            NEWSLETTER
        </div>
        <h2 class="text-2xl sm:text-3xl font-medium text-white mb-4">
            Stay Updated
        </h2>
        <p class="text-[#A8A8A8] mb-8 max-w-xl mx-auto">
            Get the latest insights on AI, MVPs, and building great products delivered to your inbox.
        </p>
        <form id="newsletter-form" action="https://api.web3forms.com/submit" method="POST"
            class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input type="hidden" name="access_key" value="e7729d29-1943-4c0b-b180-4b5d829b32b9">
            <input type="hidden" name="subject" value="New Newsletter Subscriber - Zeffron">
            <input type="hidden" name="from_name" value="Zeffron Newsletter">
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
            <input type="email" name="email" placeholder="your.email@company.com" required
                class="flex-1 px-4 py-3 bg-white/5 border border-white/10 rounded text-white placeholder-[#666] focus:outline-none focus:border-[#0145F2] transition-colors">
            <button type="submit" id="newsletter-btn"
                class="px-6 py-3 bg-[#0145F2] text-white rounded font-medium hover:bg-[#0039cc] transition-colors whitespace-nowrap">
                Subscribe
            </button>
        </form>
        <p id="newsletter-message" class="mt-4 text-sm hidden"></p>
    </div>
</section>

<section class="py-16 sm:py-20 px-4 sm:px-6 border-t border-white/10 bg-[#050505] text-center">
    <div class="max-w-3xl mx-auto reveal">
        <h2 class="text-3xl sm:text-4xl font-medium tracking-tight mb-6 text-white leading-tight">
            Ready to Build Your MVP?
        </h2>
        <p class="text-[#888] mb-10 text-lg font-light">
            Let's turn your idea into a launch-ready product in 10 days.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://cal.com/zeffron-ai/30min"
                class="px-8 py-4 bg-[#0145F2] hover:bg-[#0039cc] text-white text-sm font-medium rounded transition-all duration-200">
                Start Your MVP Sprint
            </a>
            <a href="/#pricing"
                class="px-8 py-4 border border-white/10 hover:bg-white/5 text-white text-sm font-medium rounded transition-all duration-200">
                View Pricing
            </a>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('newsletter-form');
        const btn = document.getElementById('newsletter-btn');
        const message = document.getElementById('newsletter-message');
        if (!form) return;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            btn.textContent = 'Subscribing...';
            message.classList.add('hidden');

            try {
                const response = await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    body: new FormData(form),
                });
                const result = await response.json();
                if (!result.success) throw new Error(result.message || 'Something went wrong');
                message.textContent = "Thanks for subscribing! We'll be in touch.";
                message.className = 'mt-4 text-sm text-green-400';
                form.reset();
            } catch (_err) {
                message.textContent = 'Oops! Something went wrong. Please try again.';
                message.className = 'mt-4 text-sm text-red-400';
            }

            btn.disabled = false;
            btn.textContent = 'Subscribe';
            message.classList.remove('hidden');
        });
    });
</script>

<style>
    body.home-ab-page {
        background: #08090B;
        color: #F4F1EA;
    }

    .ab-home {
        --bg: #08090B;
        --ink: #F4F1EA;
        --soft: #CFC8BA;
        --muted: #8E887E;
        --surface: rgba(244, 241, 234, 0.045);
        --surface-strong: rgba(244, 241, 234, 0.075);
        --line: rgba(244, 241, 234, 0.13);
        --brand: #0145F2;
        --brand-soft: rgba(1, 69, 242, 0.16);
        --relief: #D7A85E;
        background: var(--bg);
        color: var(--ink);
        font-family: 'Archivo', 'Inter', sans-serif;
        overflow: hidden;
    }

    .variant-clinical {
        --bg: #F5F7FA;
        --ink: #10141C;
        --soft: #344054;
        --muted: #667085;
        --surface: #FFFFFF;
        --surface-strong: #EEF3F8;
        --line: rgba(16, 20, 28, 0.13);
        --relief: #0145F2;
    }

    .variant-editorial {
        --bg: #0A0908;
        --ink: #F8F3EA;
        --soft: #D8CDBD;
        --muted: #938779;
        --surface: rgba(248, 243, 234, 0.05);
        --surface-strong: rgba(248, 243, 234, 0.085);
        --line: rgba(248, 243, 234, 0.14);
        --relief: #BFA06A;
    }

    .variant-console {
        --bg: #06080A;
        --ink: #EDF4FF;
        --soft: #B8C5D8;
        --muted: #718096;
        --surface: rgba(237, 244, 255, 0.045);
        --surface-strong: rgba(1, 69, 242, 0.11);
        --line: rgba(237, 244, 255, 0.13);
        --relief: #0145F2;
    }

    .variant-human {
        --bg: #0B0A08;
        --ink: #F6F0E6;
        --soft: #D8CCBB;
        --muted: #948A7A;
        --surface: rgba(246, 240, 230, 0.05);
        --surface-strong: rgba(246, 240, 230, 0.085);
        --line: rgba(246, 240, 230, 0.14);
        --relief: #0145F2;
    }

    .variant-engineering {
        --bg: #070A10;
        --ink: #F2F7FF;
        --soft: #C4D1E4;
        --muted: #7D8BA0;
        --surface: rgba(242, 247, 255, 0.05);
        --surface-strong: rgba(1, 69, 242, 0.13);
        --line: rgba(242, 247, 255, 0.14);
        --relief: #0145F2;
    }

    .ab-home * {
        text-wrap: pretty;
    }

    .ab-shell {
        width: min(100% - 32px, 1320px);
        margin: 0 auto;
    }

    .ab-section {
        padding: 6rem 0;
        border-bottom: 1px solid var(--line);
    }

    .ab-hero {
        min-height: 92dvh;
        padding: 7rem 0 4.5rem;
        border-bottom: 1px solid var(--line);
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 46%),
            var(--bg);
    }

    .variant-clinical .ab-hero {
        background: linear-gradient(180deg, #FFFFFF, var(--bg));
    }

    .variant-console .ab-hero {
        background:
            linear-gradient(rgba(237, 244, 255, 0.035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(237, 244, 255, 0.035) 1px, transparent 1px),
            var(--bg);
        background-size: 48px 48px;
    }

    .variant-engineering .ab-hero {
        background:
            linear-gradient(rgba(242, 247, 255, 0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(242, 247, 255, 0.035) 1px, transparent 1px),
            radial-gradient(circle at 82% 18%, rgba(1, 69, 242, 0.2), transparent 36%),
            var(--bg);
        background-size: 44px 44px, 44px 44px, auto, auto;
    }

    .ab-hero-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(22rem, 0.95fr);
        gap: 4rem;
        align-items: end;
    }

    .variant-editorial .ab-hero-layout {
        grid-template-columns: minmax(0, 1.25fr) minmax(20rem, 0.75fr);
    }

    .ab-kicker,
    .ab-label,
    .ab-metric span {
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .ab-kicker {
        display: block;
        margin-bottom: 1.3rem;
    }

    .ab-headline {
        max-width: 60rem;
        color: var(--ink);
        font-size: 3.4rem;
        line-height: 1;
        letter-spacing: 0;
        font-weight: 700;
    }

    .variant-editorial .ab-headline {
        font-family: 'Instrument Serif', Georgia, serif;
        font-weight: 700;
        line-height: 1;
    }

    .ab-subhead {
        max-width: 38rem;
        margin-top: 1.7rem;
        color: var(--soft);
        font-size: 1.18rem;
        line-height: 1.55;
    }

    .ab-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 2rem;
    }

    .ab-home .btn {
        border-radius: 6px;
        box-shadow: none;
        transition: transform 220ms cubic-bezier(0.32, 0.72, 0, 1), background-color 220ms cubic-bezier(0.32, 0.72, 0, 1), border-color 220ms cubic-bezier(0.32, 0.72, 0, 1);
    }

    .ab-home .btn:active {
        transform: scale(0.98);
    }

    .ab-home .btn-primary {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--bg);
    }

    .ab-home .btn-secondary {
        background: transparent;
        border: 1px solid var(--line);
        color: var(--ink);
    }

    .ab-visual {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        overflow: hidden;
    }

    .variant-ledger .ab-visual,
    .variant-console .ab-visual {
        border-radius: 0;
    }

    .variant-editorial .ab-visual {
        transform: translateY(2rem);
    }

    .ab-visual img {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        filter: saturate(0.85) contrast(1.03);
    }

    .variant-clinical .ab-visual img {
        filter: saturate(0.92) contrast(1.02);
    }

    .variant-console .ab-visual img {
        filter: grayscale(0.48) saturate(0.55) contrast(1.18);
    }

    .ab-visual-content {
        padding: 1.25rem;
        border-top: 1px solid var(--line);
    }

    .ab-visual-content h2 {
        color: var(--ink);
        font-size: 1.35rem;
        line-height: 1.14;
        font-weight: 600;
        margin-top: 0.75rem;
    }

    .ab-visual-content p {
        color: var(--muted);
        line-height: 1.6;
        margin-top: 0.8rem;
    }

    .ab-metrics {
        display: grid;
        gap: 1px;
        background: var(--line);
        margin-top: 1.1rem;
    }

    .ab-metric {
        background: var(--bg);
        padding: 0.8rem;
    }

    .variant-clinical .ab-metric {
        background: #FFFFFF;
    }

    .ab-split-head {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 4rem;
        align-items: end;
        margin-bottom: 3rem;
    }

    .ab-section-title {
        color: var(--ink);
        font-size: 3.8rem;
        line-height: 1;
        letter-spacing: 0;
        font-weight: 700;
        max-width: 54rem;
    }

    .variant-editorial .ab-section-title {
        font-family: 'Instrument Serif', Georgia, serif;
        font-weight: 700;
    }

    .ab-section-copy {
        max-width: 38rem;
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.65;
    }

    .ab-sector-row {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        border: 1px solid var(--line);
    }

    .ab-sector-row a {
        min-height: 7.5rem;
        padding: 1rem;
        border-right: 1px solid var(--line);
        color: var(--ink);
        text-decoration: none;
        display: flex;
        align-items: end;
        background: var(--surface);
        transition: background-color 220ms cubic-bezier(0.32, 0.72, 0, 1);
    }

    .ab-sector-row a:last-child {
        border-right: 0;
    }

    .ab-sector-row a:hover {
        background: var(--surface-strong);
    }

    .ab-logo-grid {
        display: grid;
        grid-template-columns: repeat(8, minmax(0, 1fr));
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
    }

    .ab-logo {
        min-height: 8.8rem;
        padding: 1rem;
        background: var(--surface);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .ab-logo img {
        width: 2.35rem;
        height: 2.35rem;
        object-fit: contain;
        object-position: left center;
        box-sizing: border-box;
        padding: 0.34rem;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.92);
    }

    .ab-logo strong {
        color: var(--ink);
        font-size: 0.96rem;
        line-height: 1.2;
    }

    .ab-logo .ab-tool-role {
        display: block;
        margin-top: 0.32rem;
        color: var(--muted);
        font-size: 0.78rem;
        line-height: 1.25;
    }

    .ab-vertical-card {
        display: grid;
        gap: 0.8rem;
        padding: 1.25rem;
        border: 1px solid var(--line);
        background: var(--surface-strong);
    }

    .ab-vertical-card h3 {
        color: var(--ink);
        font-size: 1.45rem;
        line-height: 1.1;
        font-weight: 600;
    }

    .ab-vertical-card p {
        color: var(--muted);
        line-height: 1.6;
    }

    .ab-problem-grid {
        display: grid;
        grid-template-columns: 0.9fr 1.15fr 0.95fr;
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-panel {
        min-height: 18rem;
        padding: 1.6rem;
        background: var(--surface);
    }

    .ab-panel h3,
    .ab-method h3,
    .ab-research-card h3 {
        margin-top: 1rem;
        color: var(--ink);
        font-size: 1.3rem;
        line-height: 1.14;
        font-weight: 600;
    }

    .ab-panel p,
    .ab-method p,
    .ab-research-card p {
        margin-top: 1rem;
        color: var(--muted);
        line-height: 1.65;
    }

    .ab-drag-list {
        counter-reset: drag;
        display: grid;
        border-top: 1px solid var(--line);
    }

    .ab-drag-item {
        counter-increment: drag;
        display: grid;
        grid-template-columns: 5rem 1fr;
        gap: 1.5rem;
        align-items: center;
        padding: 1.4rem 0;
        border-bottom: 1px solid var(--line);
    }

    .ab-drag-item::before {
        content: counter(drag, decimal-leading-zero);
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.76rem;
    }

    .ab-drag-item h3 {
        color: var(--ink);
        font-size: 2rem;
        line-height: 1.05;
        font-weight: 500;
        letter-spacing: 0;
    }

    .ab-method-grid,
    .ab-research-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-research-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ab-method,
    .ab-research-card {
        min-height: 18rem;
        padding: 1.45rem;
        background: var(--surface);
    }

    .ab-layout-note {
        max-width: 44rem;
    }

    .ab-ledger-intro,
    .ab-human-intro {
        display: grid;
        grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr);
        gap: 4rem;
        align-items: end;
        margin-bottom: 3rem;
    }

    .ab-ledger-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(20rem, 0.7fr);
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
    }

    .ab-ledger-table,
    .ab-ledger-side,
    .ab-console-terminal,
    .ab-human-toolbox {
        background: var(--surface);
    }

    .ab-ledger-row {
        display: grid;
        grid-template-columns: 0.85fr 1fr 1fr;
        gap: 1.2rem;
        padding: 1.05rem 1.2rem;
        border-bottom: 1px solid var(--line);
        color: var(--soft);
    }

    .ab-ledger-row:last-child {
        border-bottom: 0;
    }

    .ab-ledger-row strong,
    .ab-console-terminal strong,
    .ab-human-card strong {
        color: var(--ink);
        font-weight: 600;
    }

    .ab-ledger-heading {
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .ab-ledger-side {
        padding: 1.2rem;
    }

    .ab-sector-ledger,
    .ab-sector-pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-top: 1.2rem;
    }

    .ab-sector-ledger a,
    .ab-sector-pill-row a {
        border: 1px solid var(--line);
        color: var(--ink);
        text-decoration: none;
        padding: 0.62rem 0.78rem;
        background: var(--surface-strong);
        transition: background-color 220ms cubic-bezier(0.32, 0.72, 0, 1), transform 220ms cubic-bezier(0.32, 0.72, 0, 1);
    }

    .ab-sector-ledger a:hover,
    .ab-sector-pill-row a:hover {
        background: var(--brand-soft);
        transform: translateY(-2px);
    }

    .ab-capability-board {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-capability-chip {
        min-height: 9.4rem;
        padding: 1rem;
        background: var(--surface);
    }

    .ab-capability-chip h3,
    .ab-clinical-step h3,
    .ab-editorial-chapter h3,
    .ab-console-signal h3,
    .ab-human-card h3 {
        color: var(--ink);
        font-size: 1.12rem;
        line-height: 1.18;
        font-weight: 600;
    }

    .ab-capability-chip p,
    .ab-clinical-step p,
    .ab-editorial-chapter p,
    .ab-console-signal p,
    .ab-human-card p,
    .ab-human-toolbox p {
        color: var(--muted);
        line-height: 1.6;
        margin-top: 0.7rem;
    }

    .ab-clinical-band {
        display: grid;
        grid-template-columns: minmax(0, 0.84fr) minmax(0, 1.16fr);
        gap: 4rem;
        align-items: center;
    }

    .ab-clinical-path {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .ab-clinical-step {
        min-height: 17rem;
        padding: 1.2rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #FFFFFF;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .ab-clinical-step .ab-label {
        color: var(--relief);
    }

    .ab-clinical-care {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 1.2rem;
        align-items: stretch;
    }

    .ab-clinical-card {
        padding: 1.45rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #FFFFFF;
    }

    .ab-clinical-card:first-child {
        grid-row: span 2;
    }

    .ab-editorial-story {
        padding-top: 8rem;
    }

    .ab-editorial-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
        gap: 5rem;
        align-items: start;
    }

    .ab-editorial-lede {
        color: var(--ink);
        font-family: 'Instrument Serif', Georgia, serif;
        font-size: 3.8rem;
        line-height: 1;
    }

    .ab-editorial-aside {
        border-left: 1px solid var(--line);
        padding-left: 1.5rem;
    }

    .ab-editorial-index {
        display: grid;
        gap: 0.9rem;
        margin-top: 1.5rem;
    }

    .ab-editorial-index a {
        color: var(--ink);
        text-decoration: none;
        padding-bottom: 0.7rem;
        border-bottom: 1px solid var(--line);
    }

    .ab-editorial-chapters {
        display: grid;
        grid-template-columns: 1fr;
        border-top: 1px solid var(--line);
    }

    .ab-editorial-chapter {
        display: grid;
        grid-template-columns: 11rem minmax(0, 1fr);
        gap: 2rem;
        padding: 2rem 0;
        border-bottom: 1px solid var(--line);
    }

    .ab-console-deck {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(21rem, 0.95fr);
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-console-logo-wall {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1px;
        background: var(--line);
    }

    .ab-console-terminal {
        padding: 1.2rem;
    }

    .ab-console-terminal pre {
        margin-top: 1.2rem;
        overflow: auto;
        color: var(--soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.88rem;
        line-height: 1.7;
        white-space: pre-wrap;
    }

    .ab-console-signals {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-console-signal {
        min-height: 14rem;
        padding: 1rem;
        background: var(--surface);
    }

    .ab-human-journey {
        display: grid;
        grid-template-columns: minmax(20rem, 0.82fr) minmax(0, 1.18fr);
        gap: 3rem;
        align-items: start;
    }

    .ab-human-photo {
        position: sticky;
        top: 7rem;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
    }

    .ab-human-photo img {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 5;
        object-fit: cover;
        filter: saturate(0.88) contrast(1.04);
    }

    .ab-human-cards {
        display: grid;
        gap: 1.1rem;
    }

    .ab-human-card {
        padding: 1.45rem;
        border: 1px solid var(--line);
        background: var(--surface);
    }

    .ab-human-card:nth-child(2) {
        margin-left: 3rem;
    }

    .ab-human-card:nth-child(3) {
        margin-left: 6rem;
    }

    .ab-human-toolbox {
        display: grid;
        grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-human-toolbox > div {
        padding: 1.35rem;
        background: var(--surface);
    }

    .ab-engineering-system {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-engineering-panel,
    .ab-engineering-track,
    .ab-engineering-signal {
        background: var(--surface);
    }

    .ab-engineering-panel {
        padding: 1.35rem;
    }

    .ab-engineering-panel h3,
    .ab-engineering-track h3,
    .ab-engineering-signal h3 {
        color: var(--ink);
        font-size: 1.2rem;
        line-height: 1.15;
        font-weight: 600;
    }

    .ab-engineering-panel p,
    .ab-engineering-track p,
    .ab-engineering-signal p {
        margin-top: 0.75rem;
        color: var(--muted);
        line-height: 1.6;
    }

    .ab-engineering-terminal {
        min-height: 100%;
        padding: 1.35rem;
        background:
            linear-gradient(rgba(242, 247, 255, 0.04) 1px, transparent 1px),
            var(--bg);
        background-size: 100% 2.15rem;
    }

    .ab-engineering-terminal pre {
        overflow: auto;
        color: var(--soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.88rem;
        line-height: 1.75;
        white-space: pre-wrap;
    }

    .ab-engineering-track-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-engineering-track {
        min-height: 18rem;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .ab-engineering-signal-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 1px;
        border: 1px solid var(--line);
        background: var(--line);
    }

    .ab-engineering-signal {
        min-height: 13rem;
        padding: 1rem;
    }

    .ab-cta {
        padding: 6rem 0;
    }

    .ab-cta-box {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 0.8fr);
        gap: 4rem;
        align-items: end;
        padding: 2rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
    }

    @media (min-width: 760px) {
        .ab-headline {
            font-size: 4.35rem;
        }

        .ab-section-title {
            font-size: 4.15rem;
        }
    }

    @media (min-width: 1180px) {
        .ab-headline {
            font-size: 5.25rem;
        }

        .ab-section-title {
            font-size: 4.75rem;
        }
    }

    @media (max-width: 1060px) {
        .ab-hero-layout,
        .ab-split-head,
        .ab-ledger-intro,
        .ab-ledger-grid,
        .ab-clinical-band,
        .ab-clinical-care,
        .ab-editorial-grid,
        .ab-console-deck,
        .ab-human-intro,
        .ab-human-journey,
        .ab-human-toolbox,

# Copy this file to `.env` and fill in real values.
# .env is gitignored — do NOT commit it.
#
# On Railway: set each of these in Project → Variables. Skip PORT (Railway
# injects it) and skip DATABASE_URL if you've attached the Postgres plugin
# (Railway injects that too). On local dev: copy to `.env` and edit.
#
# Vars at a glance:
#   DATABASE_URL       → Postgres connection (required for the Jira board)
#   JIRA_AUTH_USER     → Basic-auth username for /jira and /api/jira/*
#   JIRA_AUTH_PASS     → Basic-auth password (set BOTH or auth is disabled)
#   RESEND_API_KEY     → Transactional email API key
#   BRIEF_NOTIFY_TO    → Where /api/brief notifications go
#   BRIEF_NOTIFY_FROM  → Sender shown on those notifications
#   NODE_ENV           → "production" enables view caching + SSL on the DB pool
#   PORT               → Local-dev port (ignored on Railway / Render / Fly)


# === Postgres (Jira board) ===========================================
# The /jira kanban + /api/jira/* endpoints persist to Postgres.
#
# On Railway: attach the Postgres plugin — DATABASE_URL is injected
# automatically and you can delete this line from your variables.
#
# Locally: point at any Postgres. Examples:
#   • Native install:  postgres://YOU@localhost:5432/zeffron_dev
#   • Docker default:  postgres://zeffron:zeffron@localhost:5432/zeffron
#   • Docker on 5433:  postgres://zeffron:zeffron@localhost:5433/zeffron
#   • Railway-style w/ SSL:  postgres://USER:PASS@HOST:5432/railway?sslmode=require
DATABASE_URL=postgres://zeffron:zeffron@localhost:5432/zeffron


# === Jira board auth =================================================
# HTTP Basic Auth gate on /jira and /api/jira/*. Set BOTH vars to enable.
# If either is missing the board is open and the boot log will warn — fine
# for local dev, fail-closed-recommended in production.
JIRA_AUTH_USER=replace-me
JIRA_AUTH_PASS=replace-me-with-a-strong-password


# === Resend (transactional email) ====================================
# Used by /api/brief to notify the team when a scoping form is submitted.
# Sign up at https://resend.com → API Keys → "Create API Key".
# Leave RESEND_API_KEY unset locally to skip emails (the brief is still
# logged to the server console and persisted to /uploads).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Single recipient address — comma-separated lists are NOT supported.
BRIEF_NOTIFY_TO=hello@zeffron.ai

# Sender on the team notification. Format: "Name <addr>". The address must
# be on a domain you've verified in Resend (e.g. notify.zeffron.ai), OR
# use Resend's sandbox sender `onboarding@resend.dev` for testing.
BRIEF_NOTIFY_FROM=Zeffron Briefs <briefs@notify.zeffron.ai>


# === Node / Server ===================================================
# NODE_ENV=production enables Express view caching and turns on SSL on the
# pg pool (required for managed Postgres like Railway). Railway sets this
# automatically — only set locally if you want to test production behaviour.
# NODE_ENV=production

# Local-dev port. Ignored on production hosts that inject their own.
# PORT=3000


# === Cloudinary (brief uploads) ======================================
# /api/brief streams every uploaded file straight into Cloudinary instead
# of writing to local disk. Get these from your Cloudinary dashboard:
# https://console.cloudinary.com → Settings → API Keys.
# All three must be set or uploads will return 503.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
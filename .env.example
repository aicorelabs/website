# Copy this file to `.env` and fill in real values.
# .env is gitignored; do not commit it.

# --- Resend (transactional email) -----------------------------------
# Sign up at https://resend.com → API Keys → create a key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where the team gets notified when a brief is submitted
BRIEF_NOTIFY_TO=hello@zeffron.ai

# Sender shown to the team. Must be on a verified domain in your Resend
# account, OR use the sandbox sender `onboarding@resend.dev` for testing.
BRIEF_NOTIFY_FROM=Zeffron Briefs <briefs@notify.zeffron.ai>

# --- Server ---------------------------------------------------------
# PORT=3000
